# Google AI API Keys (Primary key required, additional keys optional)
# Get your keys from: https://aistudio.google.com/apikey
# Required for thumbnail generation using gemini-3-pro-image-preview
# Multiple keys enable load distribution and quota management
GOOGLE_API_KEY=your_google_api_key_here
# Optional: Additional API keys for rotation (improves quota limits)
GOOGLE_API_KEY_2=your_second_api_key_optional
GOOGLE_API_KEY_3=your_third_api_key_optional

# Database URL
# PostgreSQL database (for production)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Optional: Direct URL for migrations (Supabase/connection pooling)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Registration Secret (REQUIRED for security)
# This secret is required for user registration to prevent unauthorized signups
# Generate with: openssl rand -hex 32
REGISTRATION_SECRET=your_registration_secret_here_change_in_production

# Cron Job Secret (REQUIRED for production)
# This secret protects automated cleanup and maintenance endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here_change_in_production

# Test Account Password (OPTIONAL - for demo account)
# If not set, a random password will be generated during seeding
# Only use this for development/demo environments
TEST_ACCOUNT_PASSWORD=demo_password_change_in_production

# Cloudflare R2 Storage (REQUIRED - used for image uploads)
# Get credentials from Cloudflare R2 dashboard
R2_BUCKET_NAME=your_bucket_name
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your_public_r2_domain.com

# Node Environment
NODE_ENV=development

# Credit System
# Default credits granted to new users on registration
DEFAULT_USER_CREDITS=0

# Admin Configuration
# Primary admin email for notifications and ownership fixes
ADMIN_EMAIL=admin@example.com
# Admin emails (comma-separated) - users with these emails will have admin access
ADMIN_EMAILS=admin@example.com
