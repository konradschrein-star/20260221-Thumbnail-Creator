# =============================================================================
# AI Thumbnail Rendering Farm - Environment Configuration
# =============================================================================

# =============================================================================
# AI Image Generation
# =============================================================================
# Select the active provider: "gemini" (default) or "leonardo"
IMAGE_PROVIDER=gemini

# --- Google Gemini (default provider) ---
# get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the image generation model
# GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# --- Leonardo AI (alternative provider) ---
# get key at: https://app.leonardo.ai/api-access
# LEONARDO_API_KEY=your-leonardo-api-key-here
# LEONARDO_MODEL_ID=de7d3faf-762f-48e0-b3b7-9d0ac8ed4df0


# =============================================================================
# Storage Configuration
# =============================================================================
# Use local filesystem for development (no cloud storage needed)
USE_LOCAL_STORAGE=true

# For Cloudflare R2 (optional - only if not using local storage)
# R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# R2_BUCKET_NAME=thumbnail-farm

# =============================================================================
# Database & Redis (Auto-configured by Docker)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@db:5432/thumbnail_farm
REDIS_URL=redis://redis:6379/0

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Frontend Settings
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://backend:8000
