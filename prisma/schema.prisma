generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  password       String
  name           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  role           String          @default("USER")
  channels       Channel[]       @relation("UserChannels")
  generationJobs GenerationJob[]

  @@map("users")
}

model Channel {
  id                 String          @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?         @default("#ffffff")
  secondaryColor     String?         @default("#000000")
  tags               String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  userId             String?
  archetypes         Archetype[]
  user               User?           @relation("UserChannels", fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@index([userId])
  @@map("channels")
}

model Archetype {
  id                 String          @id @default(cuid())
  name               String
  channelId          String?
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean         @default(false)
  category           String?         @default("General")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  basePrompt         String?
  channel            Channel?        @relation(fields: [channelId], references: [id])
  generationJobs     GenerationJob[]

  @@map("archetypes")
}

model GenerationJob {
  id            String       @id @default(cuid())
  channelId     String
  archetypeId   String
  userId        String?
  videoTopic    String
  thumbnailText String
  customPrompt  String?
  promptUsed    String?
  outputUrl     String?
  status        String       @default("pending")
  errorMessage  String?
  isManual      Boolean      @default(true)
  metadata      Json?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?
  archetype     Archetype    @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channel       Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])
  variants      VariantJob[]

  @@index([channelId])
  @@index([archetypeId])
  @@index([userId])
  @@index([status])
  @@index([channelId, status])
  @@map("generation_jobs")
}

model VariantJob {
  id             String        @id @default(cuid())
  masterJobId    String
  language       String
  translatedText String
  outputUrl      String?
  status         String        @default("pending")
  errorMessage   String?
  createdAt      DateTime      @default(now())
  completedAt    DateTime?
  masterJob      GenerationJob @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
  @@map("variant_jobs")
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_requests")
}
