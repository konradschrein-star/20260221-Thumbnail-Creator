generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String               @id @default(cuid())
  email                 String               @unique
  password              String
  name                  String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  role                  String               @default("USER")
  preferences           Json?                // Store custom languages and other user settings

  // Credit system
  credits               Int                  @default(0)
  totalCreditsGranted   Int                  @default(0) @map("total_credits_granted")
  totalCreditsConsumed  Int                  @default(0) @map("total_credits_consumed")

  // Password security
  passwordHashAlgorithm String               @default("bcrypt") @map("password_hash_algorithm")

  channels              Channel[]            @relation("UserChannels")
  archetypes            Archetype[]
  generationJobs        GenerationJob[]
  creditTransactions    CreditTransaction[]

  @@map("users")
}

model Channel {
  id                 String             @id @default(cuid())
  name               String
  personaDescription String
  personaAssetPath   String?
  logoAssetPath      String?
  primaryColor       String?            @default("#ffffff")
  secondaryColor     String?            @default("#000000")
  tags               String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  userId             String?
  archetypes         ChannelArchetype[]
  user               User?              @relation("UserChannels", fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@index([userId])
  @@unique([userId, name]) // Prevent duplicate channel names per user
  @@map("channels")
}

model Archetype {
  id                 String             @id @default(cuid())
  name               String
  imageUrl           String
  layoutInstructions String
  isAdminOnly        Boolean            @default(false)
  category           String?            @default("General")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  basePrompt         String?
  userId             String?
  channels           ChannelArchetype[]
  user               User?              @relation(fields: [userId], references: [id])
  generationJobs     GenerationJob[]

  @@index([userId])
  @@unique([userId, name]) // Prevent duplicate archetype names per user
  @@map("archetypes")
}

model ChannelArchetype {
  id          String    @id @default(cuid())
  channelId   String
  archetypeId String
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  archetype   Archetype @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([channelId, archetypeId])
  @@index([channelId])
  @@index([archetypeId])
  @@map("channel_archetypes")
}

model GenerationJob {
  id              String       @id @default(cuid())
  channelId       String
  archetypeId     String
  userId          String?
  videoTopic      String
  thumbnailText   String
  customPrompt    String?
  promptUsed      String?
  outputUrl       String?
  status          String       @default("pending")
  errorMessage    String?
  isManual        Boolean      @default(true)
  metadata        Json?
  creditsDeducted Int?         @map("credits_deducted") // Credit tracking
  createdAt       DateTime     @default(now())
  completedAt     DateTime?
  archetype       Archetype    @relation(fields: [archetypeId], references: [id], onDelete: Cascade)
  channel         Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id])
  variants        VariantJob[]

  @@index([channelId])
  @@index([archetypeId])
  @@index([userId])
  @@index([status])
  @@index([channelId, status])
  @@index([userId, isManual]) // Composite index for history queries
  @@index([createdAt]) // Index for sorting by creation time
  @@map("generation_jobs")
}

model VariantJob {
  id              String         @id @default(cuid())
  masterJobId     String?        // Optional - null for uploaded images
  language        String
  translatedText  String
  originalText    String?        // Original text before translation
  outputUrl       String?
  status          String         @default("pending")
  errorMessage    String?
  sourceImageUrl  String?        // For uploaded images (not from master job)
  translationMode String         @default("MASTER_JOB") // "MASTER_JOB" or "UPLOADED_IMAGE"
  createdAt       DateTime       @default(now())
  completedAt     DateTime?
  masterJob       GenerationJob? @relation(fields: [masterJobId], references: [id], onDelete: Cascade)

  @@index([masterJobId])
  @@map("variant_jobs")
}

model CreditTransaction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  transactionType String   @map("transaction_type") // "grant", "deduct", "refund"
  amount          Int      // Negative for deductions
  balanceBefore   Int      @map("balance_before")
  balanceAfter    Int      @map("balance_after")
  reason          String

  // Optional references
  relatedJobId    String?  @map("related_job_id")
  relatedBatchId  String?  @map("related_batch_id")
  adminUserId     String?  @map("admin_user_id")

  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([transactionType])
  @@index([userId, createdAt]) // Composite index for user transaction history
  @@map("credit_transactions")
}

model AccessRequest {
  id        String   @id @default(cuid())
  name      String?
  email     String
  reason    String?
  status    String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("access_requests")
}
