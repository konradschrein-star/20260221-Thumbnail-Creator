# =============================================================================
# Axtrelis Thumbnail Farm - Production Environment Configuration
# =============================================================================
# Copy this file to .env.prod and fill in your production values
# =============================================================================

# =============================================================================
# Docker Ports
# =============================================================================
FRONTEND_PORT=3068
BACKEND_PORT=8068
REDIS_PORT=6379

# =============================================================================
# Redis Security
# =============================================================================
# Generate a strong password: openssl rand -base64 32
REDIS_PASSWORD=your_redis_password_here

# =============================================================================
# Backend Configuration
# =============================================================================
ENVIRONMENT=production
DEBUG=false

# =============================================================================
# API Keys (CRITICAL: Keep these secret!)
# =============================================================================
# Your Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Session Security
# =============================================================================
# Generate a random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your_session_secret_key_here

# =============================================================================
# CORS Configuration
# =============================================================================
# Your production domain(s), comma-separated (no spaces)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# Email Configuration
# =============================================================================
SUPPORT_EMAIL=support@yourdomain.com

# =============================================================================
# Optional: External Services
# =============================================================================
# Cloudflare R2 (if using remote storage instead of local)
# R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_BUCKET_NAME=thumbnails

# Sentry (for error tracking in production)
# SENTRY_DSN=https://your-sentry-dsn-here
